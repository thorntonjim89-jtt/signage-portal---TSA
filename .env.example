# Connection string for your Netlify DB (or any Postgres database).
# When you run `netlify db init`, Netlify injects NETLIFY_DATABASE_URL
# automatically and you don't need to set this yourself in production.
# For local development against your own Postgres, set DATABASE_URL here.
DATABASE_URL=postgres://user:password@localhost:5432/signage_portal

# Secret used to sign login session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
